# Build-time env vars (Vite inlines on `bun run build` / Tauri bundle).
# Copy to `.env.local` for local dev (gitignored via *.local in .gitignore).
# In CI these come from GitHub Actions repository secrets (see .github/workflows/build.yml).

# Pre-auth endpoint bootstrap token — matches DESKTOP_BOOTSTRAP_TOKEN in octane infisical.
VITE_DESKTOP_BOOTSTRAP_TOKEN=

# Reverb/Pusher client key — matches SALES_AGENT_APP_KEY in reverb + octane infisical.
# Public-by-design (shipped in binary, broadcast to all WS clients on handshake).
VITE_SALES_AGENT_APP_KEY=

# Optional overrides; defaults bake prod URLs into source.
# VITE_SALES_AGENT_WS_HOST=reverb.pushka.biz
# VITE_SALES_AGENT_AUTH_ENDPOINT=https://octane.pushka.biz/api/desktop/v1/broadcasting/auth
